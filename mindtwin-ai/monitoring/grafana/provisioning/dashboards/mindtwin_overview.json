{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "MindTwin AI — Platform Overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100, "title": "Row 1 — Requests per Second per Service", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 },
          "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum(rate(http_requests_total[1m])) by (service)", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "title": "Requests per Second — All Services",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101, "title": "Row 2 — Response Time Percentiles", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_ms_bucket[5m])) by (le, service))", "legendFormat": "p50 {{service}}", "refId": "A" }
      ],
      "title": "p50 Response Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 3,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket[5m])) by (le, service))", "legendFormat": "p95 {{service}}", "refId": "A" }
      ],
      "title": "p95 Response Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 4,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_ms_bucket[5m])) by (le, service))", "legendFormat": "p99 {{service}}", "refId": "A" }
      ],
      "title": "p99 Response Time",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102, "title": "Row 3 — Error Rate per Service", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 },
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "id": 5,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) by (service) / sum(rate(http_requests_total[5m])) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "5xx Error Rate per Service",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103, "title": "Row 4 — Business Metrics", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "blue", "value": null }, { "color": "green", "value": 1 }
        ]}
      }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 28 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "active_study_sessions_total", "legendFormat": "Active Sessions", "refId": "A" }
      ],
      "title": "Active Study Sessions",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 28 },
      "id": 7,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum(rate(quiz_attempts_total[1m])) by (subject, gap_detected) * 60", "legendFormat": "{{subject}} gap={{gap_detected}}", "refId": "A" }
      ],
      "title": "Quiz Attempts per Minute",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 28 },
      "id": 8,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum(rate(stress_predictions_total[1h])) by (severity) * 3600", "legendFormat": "{{severity}}", "refId": "A" }
      ],
      "title": "Stress Predictions per Hour",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 36 },
      "id": 9,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum(rate(token_awards_total[5m])) by (action) * 300", "legendFormat": "{{action}}", "refId": "A" }
      ],
      "title": "Focus Token Awards per 5 min",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
      "id": 104, "title": "Row 5 — Cache Hit Rates", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 },
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "green", "value": 0.8 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 45 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(cache_hits_total[5m]) / (rate(cache_hits_total[5m]) + rate(cache_misses_total[5m]))",
          "legendFormat": "{{cache_key_type}}",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Rate by Key Type",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 45 },
      "id": 11,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum(rate(cache_hits_total[1m])) by (cache_key_type)", "legendFormat": "hits {{cache_key_type}}", "refId": "A" },
        { "expr": "sum(rate(cache_misses_total[1m])) by (cache_key_type)", "legendFormat": "misses {{cache_key_type}}", "refId": "B" }
      ],
      "title": "Cache Hits vs Misses per Minute",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 53 },
      "id": 105, "title": "Row 6 — Database Connection Pool", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 54 },
      "id": 12,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "db_pool_connections{state=\"total\"}", "legendFormat": "total {{service}}", "refId": "A" },
        { "expr": "db_pool_connections{state=\"idle\"}", "legendFormat": "idle {{service}}", "refId": "B" },
        { "expr": "db_pool_connections{state=\"waiting\"}", "legendFormat": "waiting {{service}}", "refId": "C" }
      ],
      "title": "DB Pool Connections per Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 54 },
      "id": 13,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_ms_bucket[5m])) by (le, service))", "legendFormat": "p95 {{service}}", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum(rate(db_query_duration_ms_bucket[5m])) by (le, service))", "legendFormat": "p99 {{service}}", "refId": "B" }
      ],
      "title": "DB Query Duration p95/p99",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 62 },
      "id": 106, "title": "Row 7 — Circuit Breakers & Process Health", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
          "mappings": [
            { "options": { "0": { "text": "CLOSED" }, "1": { "text": "HALF_OPEN" }, "2": { "text": "OPEN" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 2 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 63 },
      "id": 14,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "circuit_breaker_state", "legendFormat": "{{service}} → {{target}}", "refId": "A" }
      ],
      "title": "Circuit Breaker States",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 63 },
      "id": 15,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "process_resident_memory_bytes", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "title": "Process Memory (RSS) per Service",
      "type": "timeseries"
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["mindtwin", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Kolkata",
  "title": "MindTwin AI — Platform Overview",
  "uid": "mindtwin-overview-v1",
  "version": 1
}
