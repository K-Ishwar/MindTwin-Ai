#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# MindTwin AI — Pre-commit secret scanner
# Blocks commits that appear to contain hardcoded secrets.
#
# Install:
#   cp .github/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Or use the Makefile target:
#   make install-hooks
#
# Bypass (use sparingly, only for false positives):
#   git commit --no-verify
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

# Files that are allowed to contain secret-like patterns
ALLOWED_PATTERNS=(
  "\.env\.example"
  "\.env\.prod\.example"
  "package\.json"
  "package-lock\.json"
  "\.md$"
  "common_passwords\.json"
  "pre-commit"
)

# Secret patterns to scan for (regex)
SECRET_PATTERNS=(
  "password\s*=\s*['\"][^'\"]{6,}"
  "secret\s*=\s*['\"][^'\"]{8,}"
  "api_key\s*=\s*['\"][^'\"]{8,}"
  "private_key\s*=\s*['\"][^'\"]{8,}"
  "AWS_SECRET_ACCESS_KEY\s*=\s*[A-Za-z0-9/+]{20,}"
  "-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----"
  "eyJ[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{20,}"
)

# Build the grep exclude pattern
EXCLUDE_ARGS=""
for pattern in "${ALLOWED_PATTERNS[@]}"; do
  EXCLUDE_ARGS="$EXCLUDE_ARGS --exclude=$pattern"
done

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FOUND_SECRETS=0

for secret_pattern in "${SECRET_PATTERNS[@]}"; do
  # Check staged files for the pattern, excluding allowed files
  MATCHES=$(echo "$STAGED_FILES" | xargs grep -l -E "$secret_pattern" 2>/dev/null | \
    grep -v -E "$(IFS='|'; echo "${ALLOWED_PATTERNS[*]}")" || true)

  if [ -n "$MATCHES" ]; then
    echo ""
    echo "⚠️  WARNING: Possible secret detected in staged files!"
    echo "   Pattern: $secret_pattern"
    echo "   Files:   $MATCHES"
    FOUND_SECRETS=1
  fi
done

if [ "$FOUND_SECRETS" -eq 1 ]; then
  echo ""
  echo "Commit blocked. Review the files above before committing."
  echo "If this is a false positive, use: git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
