DATABASE_URL=postgres://user:password@postgres:5432/mindtwin_db
MONGODB_URI=mongodb://mongo:27017/mindtwin_db
REDIS_URL=redis://redis:6379

JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret

AUTH_SERVICE_PORT=3001
PROFILE_SERVICE_PORT=3002
SCHEDULER_SERVICE_PORT=3003
QUIZ_SERVICE_PORT=3004
STRESS_SERVICE_PORT=3005
REWARD_SERVICE_PORT=3006
NOTIFICATION_SERVICE_PORT=3007
ANALYTICS_SERVICE_PORT=3008

AI_ENGINE_URL=http://ai-engine:8000
PROFILE_SERVICE_URL=http://profile-service:3002
NOTIFICATION_SERVICE_URL=http://notification-service:3007
ANALYTICS_SERVICE_URL=http://analytics-service:3008

INTERNAL_API_KEY=internal-secret

# SMTP — configure for weekly digest emails and OTP verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@mindtwin.ai

# App URL — used in email links
APP_URL=http://localhost:3000

# PostgreSQL connection pool tuning (Phase 9.3)
PG_POOL_MAX=10
PG_POOL_MIN=2
PG_IDLE_MS=30000
PG_CONN_TIMEOUT_MS=5000
PG_STMT_TIMEOUT_MS=10000
