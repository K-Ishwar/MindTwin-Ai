# ─────────────────────────────────────────────────────────────────────────────
# MindTwin AI — Production Environment Variables
# Copy this file to .env.prod and fill in real values.
# NEVER commit .env.prod to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── PostgreSQL (AWS RDS — ap-south-1) ─────────────────────────────────────────
DATABASE_URL=postgresql://mindtwin_user:CHANGE_ME@your-rds-endpoint.ap-south-1.rds.amazonaws.com:5432/mindtwin_prod
PG_POOL_MAX=20
PG_POOL_MIN=5
PG_IDLE_MS=30000
PG_CONN_TIMEOUT_MS=5000
PG_STMT_TIMEOUT_MS=10000

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://mindtwin_user:CHANGE_ME@cluster0.xxxxx.mongodb.net/mindtwin_prod?retryWrites=true&w=majority

# ── Redis (AWS ElastiCache — cluster mode disabled) ───────────────────────────
REDIS_URL=redis://your-elasticache-endpoint.cache.amazonaws.com:6379
REDIS_TLS=true

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_256_BIT_RANDOM_HEX
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_256_BIT_RANDOM_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Internal Service Communication ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=CHANGE_ME_SECURE_RANDOM_KEY

# Service URLs (internal Docker network — do not expose externally)
AI_ENGINE_URL=http://ai-engine:8000
PROFILE_SERVICE_URL=http://profile-service:3002
NOTIFICATION_SERVICE_URL=http://notification-service:3007
ANALYTICS_SERVICE_URL=http://analytics-service:3008
SCHEDULER_SERVICE_URL=http://scheduler-service:3003
QUIZ_SERVICE_URL=http://quiz-service:3004
STRESS_SERVICE_URL=http://stress-service:3005
REWARD_SERVICE_URL=http://reward-service:3006

# Service Ports
AUTH_SERVICE_PORT=3001
PROFILE_SERVICE_PORT=3002
SCHEDULER_SERVICE_PORT=3003
QUIZ_SERVICE_PORT=3004
STRESS_SERVICE_PORT=3005
REWARD_SERVICE_PORT=3006
NOTIFICATION_SERVICE_PORT=3007
ANALYTICS_SERVICE_PORT=3008

# ── Firebase (push notifications) ────────────────────────────────────────────
# Paste the full JSON content of your Firebase service account key (minified)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"mindtwin-prod","private_key_id":"CHANGE_ME","private_key":"-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@mindtwin-prod.iam.gserviceaccount.com","client_id":"CHANGE_ME","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@mindtwin.ai
SMTP_PASS=CHANGE_ME_APP_SPECIFIC_PASSWORD
SMTP_FROM=MindTwin AI <noreply@mindtwin.ai>

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://app.mindtwin.ai

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_BUCKET=mindtwin-files-prod
AWS_S3_REGION=ap-south-1

# ── Monitoring ────────────────────────────────────────────────────────────────
# Generate a strong password: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
